# TEMMS systemd environment.
# Copy to /etc/temms/temms.env and edit per VM.

TEMMS_HOST=0.0.0.0
TEMMS_PORT=8080

# deploy/install.sh appends a generated TEMMS_API_TOKEN on first install.
# It protects control, Hub Lite, and Web UI write endpoints.
# Set TEMMS_GENERATE_API_TOKEN=false when running the installer to opt out.
# TEMMS_API_TOKEN=change-me

# Optional online Hub Lite sync. Leave unset for fully local/air-gapped mode.
# TEMMS_HUB_URL=http://hub-vm:8080
# TEMMS_HUB_TOKEN=change-me
# TEMMS_DEVICE_ID=edge-1
# TEMMS_DEVICE_PROFILE=x86_64-cpu
# TEMMS_HUB_SYNC_INTERVAL_S=30

# Optional: automatically apply assigned rollouts mirrored from Hub Lite.
# Auto-apply requires signed packages by default.
# TEMMS_HUB_AUTO_APPLY=false
# TEMMS_ROLLOUT_REQUIRE_SIGNATURE=true
# TEMMS_PACKAGE_SIGNING_KEY_FILE=/etc/temms/hub-signing.key
# TEMMS_PACKAGE_SIGNING_KEY=change-me

# Optional shared data directory override used by daemon defaults.
TEMMS_DATA_DIR=/var/lib/temms
